# Normaliza quebras de linha para LF em todos os arquivos de texto
* text=auto eol=lf

# Força LF nos arquivos de código
*.js    text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.env   text eol=lf

# Arquivos binários — sem conversão
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.svg   binary
*.ico   binary
*.webp  binary
