# E-Mais CMS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais

# ── Banco de Dados MySQL ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=conexao_farma_cms

# ── Admin ───────────────────────────────────────────────────────
# Token usado pelo painel /admin para autenticar saves na API
ADMIN_TOKEN=emais2025

# ── Servidor ────────────────────────────────────────────────────
# Hostinger define PORT automaticamente, não altere em produção
PORT=3001
NODE_ENV=development
